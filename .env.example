# Server
PORT=3000

# Azure OpenAI chat model
AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT=your-chat-deployment-name
AZURE_OPENAI_API_KEY=your-api-key

# Azure OpenAI embeddings
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_EMBED_API_VERSION=2024-02-01

# Zilliz Cloud
ZILLIZ_URI=https://your-cluster.api.region.zillizcloud.com
ZILLIZ_TOKEN=your-zilliz-api-key

# Optional integrations
SEMANTIC_SCHOLAR_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# Optional Zilliz tuning
ZILLIZ_INDEX_TYPE=HNSW
ZILLIZ_INDEX_NLIST=2048
ZILLIZ_SEARCH_NPROBE=128
ZILLIZ_SEARCH_EF=128
ZILLIZ_SEARCH_CANDIDATES_MULTIPLIER=1.5
